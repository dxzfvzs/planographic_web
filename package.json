{
  "name": "new",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://dxzfvzs.github.io/planographic_web/",
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "dependencies": {
    "fuse.js": "7.4.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^6.0.3",
    "vite": "^6.0.0"
  },
  "scripts": {
    "start": "vite",
    "build": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit && vite build",
    "gs-polygraphy": "pnpm exec ts-node --esm scripts/generate-content-structure.ts polygraphy",
    "gs-technology": "pnpm exec ts-node --esm scripts/generate-content-structure.ts technology",
    "gs-czech": "pnpm exec ts-node --esm scripts/generate-content-structure.ts czech",
    "gs-english": "pnpm exec ts-node --esm scripts/generate-content-structure.ts english",
    "gs-materials": "pnpm exec ts-node --esm scripts/generate-content-structure.ts materials",
    "gs-all": "pnpm run gs-polygraphy && pnpm run gs-technology && pnpm run gs-czech && pnpm run gs-english && pnpm run gs-materials"
  }
}
