{
  "name": "new",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://dxzfvzs.github.io/planographic_web/",
  "type": "module",
  "dependencies": {
    "gh-pages": "^6.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^6.0.3",
    "vite": "^6.0.0"
  },
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist",
    "gs-polygraphy": "npx ts-node --esm scripts/generate-content-structure.ts polygraphy",
    "gs-technology": "npx ts-node --esm scripts/generate-content-structure.ts technology",
    "gs-czech": "npx ts-node --esm scripts/generate-content-structure.ts czech",
    "gs-english": "npx ts-node --esm scripts/generate-content-structure.ts english",
    "gs-materials": "npx ts-node --esm scripts/generate-content-structure.ts materials",
    "gs-all": "npm run gs-polygraphy && npm run gs-technology && npm run gs-czech && npm run gs-english && npm run gs-materials"
  }
}
